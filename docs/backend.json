
{
  "entities": {
    "Patient": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Patient",
      "type": "object",
      "description": "A patient registered for epilepsy management and monitoring.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "location": { "type": "string" },
        "contact": { "type": "string" },
        "status": { "type": "string", "enum": ["Stable", "Urgent", "Follow-up"] },
        "registrationDate": { "type": "string", "format": "date-time" },
        "chwId": { "type": "string" }
      },
      "required": ["id", "name", "age", "gender", "location", "status"]
    },
    "ClinicalEncounter": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ClinicalEncounter",
      "type": "object",
      "description": "A recorded assessment session guided by the AI Clinical Engine.",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "summary": { "type": "string" },
        "redFlags": { "type": "array", "items": { "type": "string" } },
        "urgencyLevel": { "type": "string", "enum": ["EMERGENCY", "URGENT", "ROUTINE", "STABLE"] },
        "actionTaken": { "type": "string" },
        "authorId": { "type": "string" },
        "authorRole": { "type": "string" }
      },
      "required": ["id", "patientId", "date", "urgencyLevel"]
    },
    "HealthFacility": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "HealthFacility",
      "type": "object",
      "description": "A medical facility that accepts referrals for epilepsy patients.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["specialist", "district", "local"] },
        "address": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "contactPhone": { "type": "string" },
        "location": { "type": "string" },
        "coordinates": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        }
      },
      "required": ["id", "name", "type", "address"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/patients/{patientId}",
        "definition": {
          "entityName": "Patient",
          "schema": { "$ref": "#/backend/entities/Patient" },
          "description": "Root collection for patient profiles."
        }
      },
      {
        "path": "/patients/{patientId}/encounters/{encounterId}",
        "definition": {
          "entityName": "ClinicalEncounter",
          "schema": { "$ref": "#/backend/entities/ClinicalEncounter" },
          "description": "Sub-collection of encounter logs per patient."
        }
      },
      {
        "path": "/facilities/{facilityId}",
        "definition": {
          "entityName": "HealthFacility",
          "schema": { "$ref": "#/backend/entities/HealthFacility" },
          "description": "Registered health facilities for referrals."
        }
      }
    ]
  }
}
