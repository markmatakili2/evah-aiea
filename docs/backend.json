
{
  "entities": {
    "Profile": {
      "title": "Profile",
      "description": "User profile for CHWs, Clinicians, and Supervisors.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["chw", "clinician", "supervisor"] },
        "address": { "type": "string" },
        "location": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["id", "firstName", "lastName", "role"]
    },
    "Patient": {
      "title": "Patient",
      "description": "Epilepsy patient record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "location": { "type": "string" },
        "contact": { "type": "string" },
        "chwId": { "type": "string", "description": "The ID of the CHW who registered this patient." },
        "status": { "type": "string", "enum": ["Stable", "Urgent", "Follow-up"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "age", "gender", "chwId"]
    },
    "Encounter": {
      "title": "Encounter",
      "description": "A clinical encounter record including seizure history and AI assessment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "chwId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string" },
        "summary": { "type": "string" },
        "seizureData": { "type": "object" },
        "redFlags": { "type": "array", "items": { "type": "string" } },
        "recommendation": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "approved", "overridden"] }
      },
      "required": ["id", "patientId", "date", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/Profile" },
      "description": "Stores user profiles and roles."
    },
    "/patients/{patientId}": {
      "schema": { "$ref": "#/backend/entities/Patient" },
      "description": "Stores patient demographics."
    },
    "/patients/{patientId}/encounters/{encounterId}": {
      "schema": { "$ref": "#/backend/entities/Encounter" },
      "description": "Stores clinical encounters for a patient."
    }
  }
}
