/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for patient data and related subcollections, while allowing public read access to test and lab information.
 *
 * Data Structure:
 * - /patients/{patientId}: Stores patient profiles. Only the authenticated user matching {patientId} can read or write their own profile.
 * - /tests/{testId}: Stores publicly available test information. Anyone can read. Writes are not permitted via the client.
 * - /labs/{labId}: Stores publicly available lab information. Anyone can read. Writes are not permitted via the client.
 * - /lab_owners/{labOwnerId}: Stores lab owner profiles. Only the authenticated user matching {labOwnerId} can read or write their own profile.
 * - /lab_personnel/{labPersonnelId}: Stores lab personnel profiles. Only the authenticated user matching {labPersonnelId} can read or write their own profile.
 * - /patients/{patientId}/test_requests/{testRequestId}: Stores test requests associated with a patient. Only the patient can create, read, update, or delete their own test requests.
 * - /patients/{patientId}/test_requests/{testRequestId}/test_results/{testResultId}: Stores test results for a test request. Only the patient can create, read, update, or delete their own test results.
 * - /patients/{patientId}/test_requests/{testRequestId}/payments/{paymentId}: Stores payment information for a test request. Only the patient can create, read, update, or delete their own payment information.
 * - /patients/{patientId}/personnel_ratings/{personnelRatingId}: Stores ratings given by a patient to lab personnel. Only the patient can create, read, update, or delete their own ratings.
 * - /patients/{patientId}/abuse_reports/{abuseReportId}: Stores abuse reports submitted by patients. Only the patient can create, read, update, or delete their own abuse reports.
 *
 * Key Security Decisions:
 * - Strict user-ownership: All data under /patients/{patientId} is strictly controlled by the user matching {patientId}.
 * - Public read access: The /tests and /labs collections are publicly readable.
 * - No user listing: Listing of users (/patients, /lab_owners, /lab_personnel) is disallowed for privacy.
 *
 * Denormalization for Authorization:
 * - The 'patientId' is denormalized into the 'test_requests', 'test_results', 'payments', 'personnel_ratings', and 'abuse_reports' documents for authorization independence.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     * @path N/A
     * @allow N/A
     * @deny N/A
     * @principle Authentication is required for user-specific data access.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     * @path N/A
     * @allow N/A
     * @deny N/A
     * @principle Enforces user-ownership based on path and authentication.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of an existing document.
     * @path N/A
     * @allow N/A
     * @deny N/A
     * @principle Combines ownership check with document existence check for destructive operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Security rules for patient documents.
     * @path /patients/{patientId}
     * @allow (get, create, update, delete) if request.auth.uid == patientId
     * @deny (get, create, update, delete) if request.auth.uid != patientId
     * @principle Enforces document ownership for all operations.
     */
    match /patients/{patientId} {
      allow get: if isOwner(patientId);
      allow list: if false; // Disable listing of all users

      allow create: if isOwner(patientId) && request.resource.data.id == patientId;
      allow update: if isExistingOwner(patientId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(patientId);
    }

    /**
     * @description Security rules for test documents.
     * @path /tests/{testId}
     * @allow get, list: if true
     * @deny create, update, delete: if true
     * @principle Allows public read access to test information, but no client writes.
     */
    match /tests/{testId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Security rules for lab documents.
     * @path /labs/{labId}
     * @allow get, list: if true
     * @deny create, update, delete: if true
     * @principle Allows public read access to lab information, but no client writes.
     */
    match /labs/{labId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Security rules for lab owner documents.
     * @path /lab_owners/{labOwnerId}
     * @allow (get, create, update, delete) if request.auth.uid == labOwnerId
     * @deny (get, create, update, delete) if request.auth.uid != labOwnerId
     * @principle Enforces document ownership for all operations.
     */
    match /lab_owners/{labOwnerId} {
      allow get: if isOwner(labOwnerId);
      allow list: if false; // Disable listing of all users

      allow create: if isOwner(labOwnerId) && request.resource.data.id == labOwnerId;
      allow update: if isExistingOwner(labOwnerId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(labOwnerId);
    }

    /**
     * @description Security rules for lab personnel documents.
     * @path /lab_personnel/{labPersonnelId}
     * @allow (get, create, update, delete) if request.auth.uid == labPersonnelId
     * @deny (get, create, update, delete) if request.auth.uid != labPersonnelId
     * @principle Enforces document ownership for all operations.
     */
    match /lab_personnel/{labPersonnelId} {
      allow get: if isOwner(labPersonnelId);
      allow list: if false; // Disable listing of all users

      allow create: if isOwner(labPersonnelId) && request.resource.data.id == labPersonnelId;
      allow update: if isExistingOwner(labPersonnelId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(labPersonnelId);
    }

    /**
     * @description Security rules for test request documents under a specific patient.
     * @path /patients/{patientId}/test_requests/{testRequestId}
     * @allow (get, create, update, delete) if request.auth.uid == patientId
     * @deny (get, create, update, delete) if request.auth.uid != patientId
     * @principle Enforces document ownership for all operations.
     */
    match /patients/{patientId}/test_requests/{testRequestId} {
      allow get: if isOwner(patientId);
      allow list: if isOwner(patientId);

      allow create: if isOwner(patientId) && request.resource.data.patientId == patientId;
      allow update: if isExistingOwner(patientId) && request.resource.data.patientId == resource.data.patientId;
      allow delete: if isExistingOwner(patientId);
    }

    /**
     * @description Security rules for test result documents under a specific test request for a patient.
     * @path /patients/{patientId}/test_requests/{testRequestId}/test_results/{testResultId}
     * @allow (get, create, update, delete) if request.auth.uid == patientId
     * @deny (get, create, update, delete) if request.auth.uid != patientId
     * @principle Enforces document ownership for all operations.
     */
    match /patients/{patientId}/test_requests/{testRequestId}/test_results/{testResultId} {
      allow get: if isOwner(patientId);
      allow list: if isOwner(patientId);

      allow create: if isOwner(patientId) && request.resource.data.patientId == patientId;
      allow update: if isExistingOwner(patientId) && request.resource.data.patientId == resource.data.patientId;
      allow delete: if isExistingOwner(patientId);
    }

    /**
     * @description Security rules for payment documents under a specific test request for a patient.
     * @path /patients/{patientId}/test_requests/{testRequestId}/payments/{paymentId}
     * @allow (get, create, update, delete) if request.auth.uid == patientId
     * @deny (get, create, update, delete) if request.auth.uid != patientId
     * @principle Enforces document ownership for all operations.
     */
    match /patients/{patientId}/test_requests/{testRequestId}/payments/{paymentId} {
      allow get: if isOwner(patientId);
      allow list: if isOwner(patientId);

      allow create: if isOwner(patientId) && request.resource.data.patientId == patientId;
      allow update: if isExistingOwner(patientId) && request.resource.data.patientId == resource.data.patientId;
      allow delete: if isExistingOwner(patientId);
    }

    /**
     * @description Security rules for personnel rating documents under a specific patient.
     * @path /patients/{patientId}/personnel_ratings/{personnelRatingId}
     * @allow (get, create, update, delete) if request.auth.uid == patientId
     * @deny (get, create, update, delete) if request.auth.uid != patientId
     * @principle Enforces document ownership for all operations.
     */
    match /patients/{patientId}/personnel_ratings/{personnelRatingId} {
      allow get: if isOwner(patientId);
      allow list: if isOwner(patientId);

      allow create: if isOwner(patientId) && request.resource.data.patientId == patientId;
      allow update: if isExistingOwner(patientId) && request.resource.data.patientId == resource.data.patientId;
      allow delete: if isExistingOwner(patientId);
    }

    /**
     * @description Security rules for abuse report documents under a specific patient.
     * @path /patients/{patientId}/abuse_reports/{abuseReportId}
     * @allow (get, create, update, delete) if request.auth.uid == patientId
     * @deny (get, create, update, delete) if request.auth.uid != patientId
     * @principle Enforces document ownership for all operations.
     */
    match /patients/{patientId}/abuse_reports/{abuseReportId} {
      allow get: if isOwner(patientId);
      allow list: if isOwner(patientId);

      allow create: if isOwner(patientId) && request.resource.data.patientId == patientId;
      allow update: if isExistingOwner(patientId) && request.resource.data.patientId == resource.data.patientId;
      allow delete: if isExistingOwner(patientId);
    }
  }
}