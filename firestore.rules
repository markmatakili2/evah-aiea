rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AI EPILEPSY ASSISTANT (AIEA) SECURITY RULES
     *
     * Core Philosophy:
     * Clinical data ownership is restricted to the specific Community Health Worker (CHW) 
     * who registered the patient, or authorized supervisors for the region.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for Patient profiles. CHWs own the patients they register.
     * @path /patients/{patientId}
     */
    match /patients/{patientId} {
      // Allow read if the user is signed in
      allow read: if isSignedIn();
      
      // Allow create if the user is signed in and sets themselves as the CHW
      allow create: if isSignedIn() && request.resource.data.chwId == request.auth.uid;
      
      // Allow update if the user is the assigned CHW
      allow update: if isSignedIn() && resource.data.chwId == request.auth.uid;
      
      allow delete: if false; // Deletion restricted for clinical audit purposes
      
      /**
       * @description Sub-collection of encounter logs per patient.
       */
      match /encounters/{encounterId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if false; // Clinical records are immutable
      }
    }
  }
}